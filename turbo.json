{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "//#lint:root": {
      "inputs": [
        "$TURBO_ROOT$/*.{js,ts,mjs,cjs,vue}",
        "$TURBO_ROOT$/packages/config-eslint/src/*.js"
      ]
    },
    "//#lint:oxlint": {
      "inputs": ["$TURBO_ROOT$/**/*.{js,ts,mjs,cjs,vue,jsx,tsx}", "$TURBO_ROOT$/.oxlintrc.json"]
    },
    "//#format": {
      "cache": false
    },
    "//#format:check": {},
    "//#spell": {},
    "transit": {
      "dependsOn": ["^transit"]
    },
    "type-check": {
      "dependsOn": ["transit"]
    },
    "test": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "storybook": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "storybook:build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "clean:deps": {
      "cache": false
    },
    "clean:artifacts": {
      "cache": false
    }
  }
}
