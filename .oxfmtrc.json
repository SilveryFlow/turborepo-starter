{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "semi": false,
  "arrowParens": "avoid",
  "quoteProps": "as-needed",
  "endOfLine": "lf",
  "bracketSpacing": true,
  "htmlWhitespaceSensitivity": "css",
  "proseWrap": "preserve",
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "all",
  "ignorePatterns": [
    "dist/**",
    "dist-ssr/**",
    "*.local",
    ".turbo/**",
    ".cache/**",
    ".temp/**",
    "*.tsbuildinfo",
    "coverage/**",
    "test-results/**",
    "__snapshots__/**",
    "public/**",
    "*.min.js",
    "*.min.css",
    "*.svg",
    "*.png",
    "*.jpg",
    "*.jpeg",
    "*.gif",
    "*.ico",
    ".idea/**",
    ".DS_Store",
    "*.log",
    ".eslintcache",
    "auto-imports.d.ts",
    "components.d.ts"
  ]
}
