{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/index.css"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "lint": "eslint . --fix --cache",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist node_modules",
    "clean:deps": "rimraf node_modules",
    "clean:artifacts": "rimraf dist"
  },
  "devDependencies": {
    "@repo/config-eslint": "workspace:*",
    "@repo/config-test": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@repo/config-unocss": "workspace:*",
    "@repo/config-vite": "workspace:*",
    "@types/node": "^24.10.9",
    "@unocss/eslint-config": "^66.6.8",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vueuse/core": "^14.1.0",
    "element-plus": "^2.13.2",
    "eslint-plugin-oxlint": "~1.63.0",
    "sass-embedded": "^1.99.0",
    "typescript": "~6.0.0",
    "unocss": "^66.6.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "element-plus": "^2.13.2",
    "unocss": "^66.6.0",
    "vue": "^3.5.32"
  }
}
